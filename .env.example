# Aiven Free Tier Service URIs
# Copy this file to .env and fill in your Aiven connection details.
# NEVER commit .env to version control.

# PostgreSQL + PostGIS
AIVEN_PG_URI=postgresql+asyncpg://user:password@host:port/defaultdb?ssl=require

# Apache Kafka
AIVEN_KAFKA_BOOTSTRAP_SERVERS=host:port
AIVEN_KAFKA_SECURITY_PROTOCOL=SSL
AIVEN_KAFKA_SSL_CAFILE=certs/ca.pem
AIVEN_KAFKA_SSL_CERTFILE=certs/service.cert
AIVEN_KAFKA_SSL_KEYFILE=certs/service.key

# Valkey (Redis-compatible)
AIVEN_VALKEY_URI=rediss://default:password@host:port

# MySQL
AIVEN_MYSQL_URI=mysql+aiomysql://user:password@host:port/defaultdb?ssl=true
